<div class="auth-page">
  <div class="auth-form-container">
    <h1 class="auth-title">Войти</h1>

    <div id="global-error" class="global-error-banner hidden">
      <div class="global-error-icon">!</div>
      <span id="global-error-text">Проверьте подключение и попробуйте снова</span>
    </div>

    <form id="login-form">
      {{> input id="email" label="Email" type="email" placeholder="example@email.com" }}
      {{> input id="password" label="Пароль" type="password" placeholder="Минимум 8 символов" isPassword=true
      forgotPassword=true }}

      <button type="submit" class="btn btn-primary" style="margin-top: 0.5rem;">Войти</button>

      <p style="text-align: center; font-size: 0.875rem; color: var(--text-muted); margin-top: 1rem;">
        Нет аккаунта? <a href="#/register">Зарегистрироваться</a>
      </p>

      <div class="divider">
        <div class="divider-line"></div>Или<div class="divider-line"></div>
      </div>

      <button type="button" class="btn btn-vk" onclick="window.location.href='http://localhost:8081/auth/vk'">
        <b>VK</b> Войти с VK ID
      </button>
    </form>
  </div>

  <div class="auth-logo-container">

    <div class="auth-logo-content">
      <img src="/logo.svg" alt="NeXus Logo" style="width: 250px; margin-bottom: 1rem;" />
      <p style="color: var(--text-muted); text-align: center;">Центр управления проектами</p>
    </div>
  </div>
</div>
</div>
