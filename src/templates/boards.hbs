<div class="boards-layout">
  <div class="sidebar">
    <div class="sidebar-top">
      <div class="sidebar-icon active" style="background-color: #5c3cf6; color: white;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2L2 22h20L12 2z" />
        </svg>
      </div>
      <div class="sidebar-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="3" width="7" height="7" />
          <rect x="14" y="3" width="7" height="7" />
          <rect x="14" y="14" width="7" height="7" />
          <rect x="3" y="14" width="7" height="7" />
        </svg>
      </div>
    </div>
    <div class="sidebar-bottom">
      <div class="sidebar-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="3" />
          <path
            d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z" />
        </svg>
      </div>
      <div class="sidebar-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
          <path d="M13.73 21a2 2 0 0 1-3.46 0" />
        </svg>
      </div>
      <div class="sidebar-avatar" style="background-image: url('https://i.pravatar.cc/100?img=5');"></div>
    </div>
  </div>

  <div class="main-content">
    <div class="boards-header-container">
      <div class="boards-title-group">
        <h1 class="boards-title">Доски <span class="boards-count">{{boards.length}}</span></h1>
        <button class="btn-create">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 5v14M5 12h14" />
          </svg>
          Создать
        </button>
      </div>
      <div class="search-container">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input type="text" class="search-input" placeholder="Поиск доски или задачи">
      </div>
    </div>

    <div class="boards-grid">
      {{#each boards}}
      <div class="board-card">
        <div class="board-card-top">
          <div class="board-header">
            <div class="board-title-group">
              <div class="board-icon" style="background-color: {{iconBg}}">
                {{{iconSvg}}}
              </div>
              <h2 class="board-name">{{board_name}}</h2>
            </div>
            <button class="board-options-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <circle cx="5" cy="12" r="2" />
                <circle cx="12" cy="12" r="2" />
                <circle cx="19" cy="12" r="2" />
              </svg>
            </button>
          </div>
          <p class="board-desc">{{description}}</p>
        </div>

        <div class="board-card-bottom">
          <div class="board-divider"></div>
          <div class="board-stats">
            <div class="stat-item">
              <div class="stat-value-wrapper">
                <div class="stat-value">{{backlog}}</div>
              </div>
              <div class="stat-label">Задачи<br>в бэклоге</div>
            </div>
            <div class="stat-item">
              <div class="stat-value-wrapper">
                <div class="stat-value">{{hot}}</div>
                {{#if hot}}<span class="fire">🔥</span>{{/if}}
              </div>
              <div class="stat-label">Горящие<br>задачи</div>
            </div>
            <div class="stat-item">
              <div class="stat-value-wrapper">
                <div class="stat-value">{{members}}</div>
                <div class="avatars-inline">
                  {{#each avatars}}
                  <div class="avatar-circle" style="background-image: url('{{this}}');"></div>
                  {{/each}}
                </div>
              </div>
              <div class="stat-label">Человек состоит<br>в команде</div>
            </div>
          </div>
        </div>
      </div>
      {{else}}
      <p style="color: var(--text-muted);">У вас пока нет досок.</p>
      {{/each}}
    </div>
  </div>
</div>
