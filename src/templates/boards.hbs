<div class="boards-layout">
  <div class="sidebar">
    <div class="sidebar-top">
      <div class="sidebar-icon active sidebar-icon-primary" title="Доски">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M6 2h12v4l-4 6 4 6v4H6v-4l4-6-4-6V2z" />
          <line x1="6" y1="2" x2="18" y2="2" />
          <line x1="6" y1="22" x2="18" y2="22" />
        </svg>
      </div>
    </div>
    <div class="sidebar-bottom">
      <div class="sidebar-icon cursor-pointer" id="profile-btn" title="Профиль">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </div>
      <div class="sidebar-icon sidebar-icon-logout cursor-pointer" id="logout-btn" title="Выйти из аккаунта">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
          <polyline points="16 17 21 12 16 7"></polyline>
          <line x1="21" y1="12" x2="9" y2="12"></line>
        </svg>
      </div>
    </div>
  </div>

  <div class="main-content">
    <div class="boards-header-container">
      <div class="boards-title-group">
        <h1 class="boards-title">Досок <span class="boards-count">{{boards.length}}</span></h1>
      </div>
      <div class="search-container">
        <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <input type="text" class="search-input" placeholder="Поиск доски или задачи">
      </div>
    </div>

    <div class="boards-grid">
      {{#each boards}}
      <div class="board-card">
        <div class="board-card-top">
          <div class="board-header">
            <div class="board-title-group">
              <div class="board-icon {{iconClass}}">
                {{{iconHtml}}}
              </div>
              <h2 class="board-name" title="{{board_name}}">{{board_name}}</h2>
            </div>
          </div>
          <p class="board-desc" title="{{description}}">{{description}}</p>
        </div>

        <div class="board-card-bottom">
          <div class="board-divider"></div>
          <div class="board-stats">
            <div class="stat-item">
              <div class="stat-value-wrapper">
                <span class="stat-value">{{backlog}}</span>
              </div>
              <div class="stat-label">Задачи<br>в бэклоге</div>
            </div>
            <div class="stat-item">
              <div class="stat-value-wrapper">
                <span class="stat-value">{{hot}}</span>
                {{#if hot}}<span class="fire">🔥</span>{{/if}}
              </div>
              <div class="stat-label">Горящие<br>задачи</div>
            </div>
            
            {{#if hasMembers}}
            <div class="stat-item">
              <div class="stat-value-wrapper">
                <span class="stat-value">{{members}}</span>
                {{#if avatars}}
                <div class="avatars-inline">
                  {{#each avatars}}
                  <img src="{{this}}" alt="avatar" class="avatar-circle">
                  {{/each}}
                </div>
                {{/if}}
              </div>
              <div class="stat-label">Человек состоит<br>в команде</div>
            </div>
            {{/if}}
          </div>
        </div>
      </div>
      {{/each}}
    </div>
  </div>
</div>

{{#if user}}
<div id="profile-popup" class="profile-popup hidden">
  <div class="profile-popup-avatar">
    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
      <circle cx="12" cy="7" r="4"></circle>
    </svg>
  </div>
  <div class="profile-popup-info">
    <div class="profile-name">{{user.display_name}}</div>
    <div class="profile-email">{{user.email}}</div>
  </div>
</div>
{{/if}}

<div id="modal-overlay" class="modal-overlay hidden">
  <div id="modal-create-board" class="modal hidden">
    <h2 class="modal-title">Создать новую доску</h2>
    <div class="input-group">
      <label class="input-label" for="new-board-name">Название доски</label>
      <input type="text" id="new-board-name" class="input-field" placeholder="Например, Новый проект" autocomplete="off" />
    </div>
    <div class="modal-actions">
      <button class="btn btn-cancel" id="btn-cancel-create">Отмена</button>
      <button class="btn btn-primary" id="btn-confirm-create" disabled>Создать</button>
    </div>
  </div>

  <div id="modal-delete-board" class="modal hidden">
    <h2 class="modal-title">Удалить доску?</h2>
    <p class="modal-text">Вы уверены, что хотите удалить доску "<span id="delete-board-name" style="color: white; font-weight: bold;"></span>"?<br><br>Это действие нельзя отменить.</p>
    <div class="modal-actions">
      <button class="btn btn-cancel" id="btn-cancel-delete">Отмена</button>
      <button class="btn btn-danger" id="btn-confirm-delete">Удалить</button>
    </div>
  </div>

  <div id="modal-logout" class="modal hidden">
    <h2 class="modal-title">Выход из аккаунта</h2>
    <p class="modal-text">Вы уверены, что хотите выйти?</p>
    <div class="modal-actions">
      <button class="btn btn-cancel" id="btn-cancel-logout">Отмена</button>
      <button class="btn btn-danger" id="btn-confirm-logout">Выйти</button>
    </div>
  </div>
</div>
