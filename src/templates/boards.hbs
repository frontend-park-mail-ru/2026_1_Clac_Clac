<div class="boards-layout">
  {{> sidebar activeBoards=true}}

  <div class="main-content">
    <div class="boards-header-container"
      style="display: flex; gap: 1.5rem; align-items: center; border-bottom: 1px solid #2a2a2c; padding-bottom: 1.5rem; margin-bottom: 2rem;">
      <h1 class="boards-title" style="font-size: 1.8rem; font-weight: 700; margin: 0; color: white;">
        {{#if (eq boards.length 0)}}Досок{{else}}Доски{{/if}}
        <span class="boards-count" style="color: #555;">{{boards.length}}</span>
      </h1>
      <button class="btn btn-primary btn-create" id="btn-create-board"
        style="padding: 0.6rem 1.2rem; border-radius: 12px; display: flex; align-items: center; gap: 0.5rem; font-size: 0.95rem; font-weight: 500; width: auto;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="5" x2="12" y2="19"></line>
          <line x1="5" y1="12" x2="19" y2="12"></line>
        </svg>
        Создать
      </button>
    </div>

    {{#if (eq boards.length 0)}}
    <div class="boards-grid">
      <div class="board-card-empty-large" id="btn-create-board-empty">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="#8b5cf6" stroke-width="1.5"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="4" x2="12" y2="20"></line>
          <line x1="4" y1="12" x2="20" y2="12"></line>
        </svg>
      </div>
    </div>
    {{else}}
    <div class="boards-grid">
      {{#each boards}}
      <div class="board-card" data-id="{{id}}">
        <div class="board-card-top">
          <div class="board-header"
            style="display: flex; justify-content: space-between; align-items: flex-start; width: 100%;">
            <div class="board-title-group" style="display: flex; gap: 1rem; align-items: center;">
              <div class="board-icon-monitor">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="2"
                  stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="4" width="18" height="12" rx="2"></rect>
                  <path d="M12 16v4M8 22l4-4 4 4"></path>
                </svg>
              </div>
              <div style="display: flex; flex-direction: column; gap: 0.3rem;">
                <h2 class="board-name" style="font-size: 1.15rem; font-weight: bold; margin: 0; color: white;">
                  {{board_name}}</h2>
                <p class="board-desc" style="color: #777; font-size: 0.85rem; margin: 0;">{{description}}</p>
              </div>
            </div>
            <button class="icon-btn board-options-btn" data-id="{{id}}" data-name="{{board_name}}"
              style="background: #2a2a2c; padding: 0.4rem; border-radius: 8px;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <circle cx="5" cy="12" r="2" />
                <circle cx="12" cy="12" r="2" />
                <circle cx="19" cy="12" r="2" />
              </svg>
            </button>
          </div>
        </div>

        <div class="board-card-bottom">
          <div class="board-divider" style="height: 1px; background: #2a2a2c; margin: 1.2rem 0;"></div>
          <div class="board-stats" style="display: flex; justify-content: space-between; text-align: center;">
            <div class="stat-item" style="flex: 1;">
              <div class="stat-value" style="font-size: 2rem; font-weight: 700; color: #555;">{{backlog}}</div>
              <div class="stat-label" style="font-size: 0.75rem; color: #777; margin-top: 0.2rem; line-height: 1.3;">
                Задачи<br>в бэклоге</div>
            </div>
            <div class="stat-item" style="flex: 1;">
              <div class="stat-value" style="font-size: 2rem; font-weight: 700; color: #555;">{{hot}}</div>
              <div class="stat-label" style="font-size: 0.75rem; color: #777; margin-top: 0.2rem; line-height: 1.3;">
                Горящих<br>задач</div>
            </div>
            <div class="stat-item" style="flex: 1;">
              <div class="stat-value" style="font-size: 2rem; font-weight: 700; color: #555;">{{members}}</div>
              <div class="stat-label" style="font-size: 0.75rem; color: #777; margin-top: 0.2rem; line-height: 1.3;">
                Человек состоит<br>в команде</div>
            </div>
          </div>
        </div>
      </div>
      {{/each}}
    </div>
    {{/if}}
  </div>
</div>

<div id="modal-overlay" class="modal-overlay hidden">

  <div id="modal-create-board" class="modal hidden">
    <div class="modal-header"
      style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
      <h2 class="modal-title" style="font-weight: 700; font-size: 1.5rem; color: white; margin: 0;">Создать доску</h2>
      <button class="close-modal-btn"
        style="padding: 0; background: transparent; border: none; color: #aaa; cursor: pointer;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="modal-body" style="margin-bottom: 2rem;">
      <label for="create-board-image" class="modal-image-row"
        style="display: flex; align-items: center; gap: 0.8rem; color: white; margin-bottom: 1.5rem; font-size: 0.95rem; cursor: pointer; width: max-content;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span id="create-board-image-name">Изображение доски</span>
        <input type="file" id="create-board-image" class="hidden" accept="image/*" />
      </label>
      <div class="input-group" style="margin-bottom: 0;">
        <label class="input-label"
          style="margin-bottom: 0.6rem; display: block; font-size: 0.85rem; color: #ccc;">Название доски</label>
        <input type="text" id="new-board-name" class="input-field" placeholder="Например, Запуск продукта"
          autocomplete="off"
          style="background: #18181a; border: 1px solid transparent; color: white; padding: 0.8rem 1rem;" />
        <span class="input-error-msg" id="new-board-name-error"
          style="color: #ff5c5c; font-size: 0.85rem; margin-top: 0.5rem; display: none;">Введите имя доски</span>
      </div>
    </div>
    <button class="btn btn-primary btn-modal-action" id="btn-confirm-create" disabled
      style="width: 100%; border-radius: 8px; font-weight: 500;">Создать</button>
  </div>

  <div id="modal-edit-board" class="modal hidden">
    <div class="modal-header"
      style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
      <h2 class="modal-title" style="font-weight: 700; font-size: 1.5rem; color: white; margin: 0;">Изменить доску</h2>
      <button class="close-modal-btn"
        style="padding: 0; background: transparent; border: none; color: #aaa; cursor: pointer;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="modal-body" style="margin-bottom: 2rem;">
      <label for="edit-board-image" class="modal-image-row"
        style="display: flex; align-items: center; gap: 0.8rem; color: white; margin-bottom: 1.5rem; font-size: 0.95rem; cursor: pointer; width: max-content;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span id="edit-board-image-name">Изображение доски</span>
        <input type="file" id="edit-board-image" class="hidden" accept="image/*" />
      </label>
      <div class="input-group" style="margin-bottom: 0;">
        <label class="input-label"
          style="margin-bottom: 0.6rem; display: block; font-size: 0.85rem; color: #ccc;">Другое название доски</label>
        <input type="text" id="edit-board-name" class="input-field" placeholder="Например, Запуск продукта"
          autocomplete="off"
          style="background: #18181a; border: 1px solid transparent; color: white; padding: 0.8rem 1rem;" />
      </div>
    </div>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <button class="btn btn-primary btn-modal-action" id="btn-confirm-edit" disabled
        style="width: 100%; border-radius: 8px; font-weight: 500;">Изменить</button>
      <button class="btn btn-danger" id="btn-open-delete"
        style="width: 100%; padding: 0.9rem; border-radius: 8px; border: none; font-weight: 500; font-size: 1rem; cursor: pointer; background-color: #ff6b6b; color: white;">Удалить</button>
    </div>
  </div>

  <div id="modal-delete-board" class="modal hidden">
    <div class="modal-header"
      style="margin-bottom: 1.5rem; display: flex; justify-content: space-between; align-items: center;">
      <h2 class="modal-title" style="font-weight: 700; font-size: 1.5rem; color: white; margin: 0;">Удалить доску</h2>
      <button class="close-modal-btn"
        style="padding: 0; background: transparent; border: none; color: #aaa; cursor: pointer;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <p class="modal-text" style="color: white; font-size: 1rem; margin-bottom: 2rem; line-height: 1.5;">Вы уверены, что
      хотите удалить доску<br>“<span id="delete-board-name" style="font-weight: bold;"></span>”?</p>
    <div class="modal-actions" style="display: flex; gap: 1rem;">
      <button class="btn btn-danger" id="btn-confirm-delete"
        style="flex: 1; padding: 0.9rem; border-radius: 8px; border: none; font-weight: 500; font-size: 1rem; cursor: pointer; background-color: #ff6b6b; color: white;">Удалить</button>
      <button class="btn btn-cancel close-modal-btn"
        style="flex: 1; padding: 0.9rem; border-radius: 8px; border: 1px solid #444; background: transparent; color: #ccc; font-weight: 500; font-size: 1rem; cursor: pointer;">Отменить</button>
    </div>
  </div>
</div>
