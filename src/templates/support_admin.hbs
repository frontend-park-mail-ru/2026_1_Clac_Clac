<div class="boards__layout">
  {{> sidebar activeSupport=true}}

  <div class="main-content">
    <h1 class="boards__title mb-1">Панель управления поддержкой</h1>

    <div class="support-admin__stats mb-1">
      <div class="stat-card">
        <h3>Всего обращений</h3>
        <div class="val">{{statistics.total}}</div>
      </div>
      <div class="stat-card">
        <h3>Открыто / В работе</h3>
        <div class="val">{{statistics.open}}</div>
      </div>
      <div class="stat-card">
        <h3>Закрыто</h3>
        <div class="val">{{statistics.closed}}</div>
      </div>
      <div class="stat-card">
        <h3>Средняя оценка</h3>
        <div class="val">{{statistics.avgRating}} ★</div>
      </div>
    </div>

    <div class="support-admin__layout">
      <div class="support-admin__list">
        <h3 style="margin-top:0;">Список тикетов</h3>
        {{#each tickets}}
          <div class="support-widget__ticket sa-ticket-item" data-id="{{id}}" {{#if (eq ../currentTicket.id id)}}style="border-color: #8b5cf6;"{{/if}}>
            <h4>{{title}}</h4>
            <div style="display:flex; justify-content:space-between; margin-top:0.5rem; align-items: center;">
              <span class="status status-{{status}}">
                {{#if (eq status 'open')}}Открыто{{/if}}{{#if (eq status 'in_progress')}}В работе{{/if}}{{#if (eq status 'closed')}}Закрыто{{/if}}
              </span>
              <span style="font-size:0.8rem; color:#888;">Линия: {{support_line}}</span>
            </div>
          </div>
        {{/each}}
      </div>

      <div class="support-admin__detail">
        {{#if currentTicket}}
          <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:1rem;">
            <h2 style="margin:0;">{{currentTicket.title}}</h2>
            <div style="display:flex; gap:0.5rem; align-items:center;">
              <select id="sa-status-select" class="input-group__field" style="width:auto; padding:0.4rem;">
                <option value="open" {{#if (eq currentTicket.status 'open')}}selected{{/if}}>Открыто</option>
                <option value="in_progress" {{#if (eq currentTicket.status 'in_progress')}}selected{{/if}}>В работе</option>
                <option value="closed" {{#if (eq currentTicket.status 'closed')}}selected{{/if}}>Закрыто</option>
              </select>
              {{#if (eq currentTicket.support_line 1)}}
                <button class="btn btn--secondary" id="sa-escalate" title="Перевести на 2-ю линию (сложные тех. вопросы)">На 2 линию</button>
              {{/if}}
            </div>
          </div>
          <p style="color:#aaa; margin-top:0;">Категория: {{currentTicket.category}}</p>

          <div class="support-widget__messages" id="sa-messages" style="background:#1e1e20; padding:1rem; border-radius:8px;">
            <div class="msg msg-user" style="background:#444; align-self:flex-start;">
              <strong>Описание пользователя:</strong><br>{{currentTicket.description}}
            </div>
            {{#each currentTicket.messages}}
              <div class="msg msg-{{sender}}" {{#if (eq sender 'user')}}style="align-self:flex-start; background:#444;"{{else}}style="align-self:flex-end; background:#8b5cf6;"{{/if}}>
                {{text}}
              </div>
            {{/each}}
          </div>

          <div class="support-widget__input-area mt-1">
            <input type="text" id="sa-msg-text" class="input-group__field" placeholder="Ответ пользователю...">
            <button class="btn btn--primary" id="sa-btn-send" style="width:auto;">Отправить</button>
          </div>
        {{else}}
          <div style="display:flex; align-items:center; justify-content:center; height:100%; color:#888;">
            Выберите обращение из списка для ответа
          </div>
        {{/if}}
      </div>
    </div>
  </div>
</div>
